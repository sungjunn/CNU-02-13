ANTHROPIC_API_KEY=your-key-here
OPENAI_API_KEY=your-key-here

# OpenRouter (openrouter/anthropic/claude-sonnet-4-5 형식으로 사용)
OPENROUTER_API_KEY=your-key-here

# Factchat Gateway (OpenAI 호환 — factchat/claude-sonnet-4-6 형식으로 사용)
FACTCHAT_API_KEY=your-key-here
FACTCHAT_BASE_URL=https://factchat-cloud.mindlogic.ai/v1/gateway

# 파이프라인 LLM — 아래 중 하나 선택
# DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
# DEFAULT_MODEL=openrouter/anthropic/claude-sonnet-4-5
# DEFAULT_MODEL=factchat/claude-sonnet-4-6
DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514

# LLM-as-Judge 모델 — 파이프라인과 다른 모델 사용 (self-preference bias 방지)
# 미설정 시 문자열 포함 여부로 폴백.
JUDGE_MODEL=openai/gpt-4o-mini

DB_PATH=db/patent_agent.db

# Langfuse — 트레이싱 (미설정 시 비활성화)
LANGFUSE_PUBLIC_KEY=your-public-key-here
LANGFUSE_SECRET_KEY=your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com
